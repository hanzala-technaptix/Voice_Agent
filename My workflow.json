    {
      "parameters": {
        "jsCode": "const TRIGGER = new Set(['New Lead', 'Call', 'Retry', 'Follow-up']);\nconst now = new Date();\nconst e164 = /^\\+[1-9]\\d{6,14}$/;\n\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  const status = (j['Call Status'] || '').trim();\n  if (!TRIGGER.has(status) || status === 'Calling') continue;\n\n  const nextAt = (j['Next Call At'] || '').trim();\n  if (nextAt) {\n    const t = new Date(nextAt);\n    if (!isNaN(t.getTime()) && t > now) continue;\n  }\n\n  const raw = String(j['Phone'] || '').trim();\n  let phone;\n  if (raw.startsWith('+')) {\n    phone = '+' + raw.slice(1).replace(/\\D/g, '');\n  } else {\n    const digits = raw.replace(/\\D/g, '');\n    if (digits.length === 10) phone = '+1' + digits;\n    else if (digits.length === 11 && digits[0] === '1') phone = '+' + digits;\n    else phone = digits ? '+' + digits : '';\n  }\n  if (!e164.test(phone)) continue;\n\n  let trigger_type = 'retry';\n  if (status === 'New Lead') trigger_type = 'new';\n  else if (status === 'Follow-up') trigger_type = 'follow_up';\n  else if (status === 'Call') trigger_type = 'call';\n\n  const attempt = parseInt(j['Call Attempt'] || '0', 10) || 0;\n  out.push({\n    json: {\n      ...j,\n      phone,\n      lead_id: j['Lead ID'],\n      name: (j['name'] || '').trim(),\n      company: (j['company'] || '').trim(),\n      email: (j['email'] || '').trim().toLowerCase(),\n      notes: (j['notes'] || '').trim(),\n      trigger_type,\n      call_attempt: attempt + 1,\n    }\n  });\n}\nreturn out;"
      },
      "id": "prepare-lead",
      "name": "Prepare Lead",
      "type": "n8n-nodes-base.code",

      "parameters": {
        "jsCode": "const j = $input.first().json;\nconst cleaned = String(j.phone || '').replace(/\\D/g, '');\nconst timezoneMap = {\n  '1': 'America/New_York',\n  '44': 'Europe/London',\n  '61': 'Australia/Sydney',\n  '92': 'Asia/Karachi',\n};\nlet timezone = 'America/New_York';\nfor (const code of Object.keys(timezoneMap).sort((a, b) => b.length - a.length)) {\n  if (cleaned.startsWith(code)) { timezone = timezoneMap[code]; break; }\n}\nconst parts = new Intl.DateTimeFormat('en-GB', {\n  timeZone: timezone, hour: 'numeric', hour12: false,\n}).formatToParts(new Date());\nconst localHour = parseInt(parts.find(p => p.type === 'hour').value, 10);\nreturn [{ json: { ...j, timezone, localHour } }];"
      },

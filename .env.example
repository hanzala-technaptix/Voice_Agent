# Technaptix Voice Agent — Runtime Configuration Template
#
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in EVERY value with your actual credentials
# 3. Run: python check_setup.py
# 4. NEVER commit .env to git
# 5. .env is in .gitignore — it will be ignored automatically

# ============================================================================
# LIVEKIT CLOUD
# ============================================================================
# Get from: https://cloud.livekit.io/projects → Settings → Keys
# Click "Generate New Key" for fresh credentials
LIVEKIT_URL=wss://your-instance.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your-api-secret-here

# ============================================================================
# SIP OUTBOUND TRUNK
# ============================================================================
# Get from: LiveKit Web dashboard → Ingress → SIP Trunks
# Run: lk sip outbound create livekit/outbound-trunk.json
# Caller ID should match your Telnyx account
SIP_CALLER_ID=+1xxxxxxxxxx
SIP_OUTBOUND_TRUNK_ID=ST_xxxxxxxxxxxxxxxx
SIP_RING_TIMEOUT_SEC=90
SIP_DIAL_EXTRA_TIMEOUT_SEC=20

# ============================================================================
# SPEECH-TO-TEXT (STT) — GLADIA
# ============================================================================
# Get from: https://console.gladia.io/account/api-keys
# Model: "solaria-1" or "solaria-2"
# Language: "en-US", "en", "fr-FR", "de", "es", etc.
STT_BACKEND=gladia
STT_MODEL=solaria-1
STT_LANGUAGE=en-US
STT_REGION=us-west
STT_INTERIM_RESULTS=true
STT_ENDPOINTING_MS=300
STT_MAX_DURATION_NO_EOS_S=10
STT_AUDIO_ENHANCER=true
STT_SPEECH_THRESHOLD=0.3

# ============================================================================
# TEXT-TO-SPEECH (TTS) — TELNYX
# ============================================================================
# Get from: https://portal.telnyx.com/ → Account → API Keys
# Voice: "Telnyx.NaturalHD.astra" (recommended) or other Telnyx voice
TELNYX_API_KEY=your-telnyx-api-key-here
TTS_BACKEND=telnyx
TELNYX_TTS_VOICE=Telnyx.NaturalHD.astra

# ============================================================================
# LLM — PRIMARY MODEL
# ============================================================================
# Option 1: GROQ (Recommended — fast & cheap)
#   Get from: https://console.groq.com/keys
LLM_BACKEND=groq
LLM_MODEL_GROQ=mixtral-8x7b-32768
LLM_TEMPERATURE=0.7
LLM_PARALLEL_TOOL_CALLS=true
GROQ_REASONING_EFFORT=

# Option 2: OPENAI (Fallback)
#   Get from: https://platform.openai.com/account/api-keys
# LLM_BACKEND=openai
LLM_MODEL_OPENAI=gpt-4o-mini
OPENAI_API_KEY=sk-proj-your-openai-key-here

# LLM Fallback (use OpenAI if Groq fails)
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_ATTEMPT_TIMEOUT_SEC=10
LLM_FALLBACK_MAX_RETRY_PER_LLM=2
LLM_FALLBACK_RETRY_ON_CHUNK_SENT=false

# ============================================================================
# CAL.COM — MEETING BOOKING
# ============================================================================
# Get from: https://app.cal.com/settings/developer/api-keys
# Event Type ID: https://app.cal.com/event-types → click your event → copy ID
CALCOM_API_KEY=cal_live_your-calcom-key-here
CALCOM_EVENT_TYPE_ID=your-event-type-id

# ============================================================================
# N8N — WORKFLOW AUTOMATION (RESULTS WEBHOOK)
# ============================================================================
# Flow B ingests call results from this webhook
# Local: http://localhost:5678/webhook/voice-results
# Production: https://your-n8n-domain.com/webhook/voice-results
N8N_RESULTS_WEBHOOK=http://localhost:5678/webhook/voice-results
N8N_RESULTS_TIMEOUT_SEC=30
N8N_RESULTS_MAX_RETRIES=3

# ============================================================================
# GOOGLE SHEETS — LEAD MANAGEMENT (PHASE 2)
# ============================================================================
# Get from: Google Cloud Console → Service Accounts → JSON key
# Sheet ID: https://docs.google.com/spreadsheets/d/SHEET_ID/edit → copy ID
# Tab: worksheet name (default: "Lead")
LEAD_SHEET_ID=your-google-sheet-id-here
LEAD_SHEET_TAB=Lead
GOOGLE_SERVICE_ACCOUNT_JSON=service-account.json
DEFAULT_LEAD_SOURCE=manual
LEAD_AUDIT_LOG=leads.log

# ============================================================================
# AGENT BEHAVIOR
# ============================================================================
# Timezone for all conversational context (e.g., "Let me check Tuesday")
PROSPECT_TZ=America/New_York

# Max call duration before watchdog forces graceful close
MAX_CALL_DURATION_SEC=300
WATCHDOG_SOFT_LIMIT_BUFFER_SEC=20

# Max concurrent calls (limit parallelism to avoid resource exhaustion)
MAX_CONCURRENT_CALLS=3

# Dry run mode: set to true to test without placing real calls
DRY_RUN=false

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
# Call results are appended as JSON (one per line)
CALLS_LOG=calls.log

# Lead collection audit trail
LEADS_LOG=leads.log

# Agent build/version tag (for tracking which version is running)
AGENT_BUILD=2026-07-02-production
AGENT_NAME=outbound-caller

# ============================================================================
# TURN-TAKING & INTERRUPTION
# ============================================================================
# VAD silence threshold (seconds before turn is considered complete)
VAD_MIN_SILENCE_SEC=0.5

# Endpointing mode: "vad" (server-side) or "hybrid" (combined)
ENDPOINTING_MODE=hybrid
MIN_ENDPOINTING_DELAY_SEC=0.1
MAX_ENDPOINTING_DELAY_SEC=1.0

# Interruption settings
INTERRUPTION_ENABLED=true
RESUME_FALSE_INTERRUPTION=true
FALSE_INTERRUPTION_TIMEOUT_SEC=1.0
MIN_INTERRUPTION_DURATION_SEC=0.5
MIN_INTERRUPTION_WORDS=2
BACKCHANNEL_BOUNDARY_START_SEC=2.0
BACKCHANNEL_BOUNDARY_END_SEC=10.0

# Preemptive generation (start TTS before LLM is done)
PREEMPTIVE_GENERATION=true
PREEMPTIVE_TTS=true
PREEMPTIVE_MAX_SPEECH_DURATION_SEC=5.0
PREEMPTIVE_MAX_RETRIES=3

# Min delay before consecutive speech
MIN_CONSECUTIVE_SPEECH_DELAY_SEC=0.3

# AEC (Acoustic Echo Cancellation) warmup
AEC_WARMUP_DURATION_SEC=1.0

# User away timeout (silence before "are you there?")
USER_AWAY_TIMEOUT_SEC=10.0

# ============================================================================
# BACKGROUND AUDIO (THINKING SOUND)
# ============================================================================
# Play "thinking" sound while LLM processes
THINKING_SOUND_ENABLED=true
THINKING_SOUND_VOLUME=0.5

# ============================================================================
# DEAD AIR WATCHDOG
# ============================================================================
# Check for silence every N seconds
DEAD_AIR_POLL_SEC=2.0

# Timeout before recovery attempt (seconds)
DEAD_AIR_TIMEOUT_SEC=5.0

# Max recovery attempts before giving up
MAX_DEAD_AIR_RECOVERIES=2

# ============================================================================
# SESSION & STARTUP
# ============================================================================
# Timeout waiting for session.start() to complete
SESSION_START_TIMEOUT_SEC=10.0

# Goodbye detection & nudge timeout
GOODBYE_NUDGE_TIMEOUT_SEC=2.0

# ============================================================================
# DEBUGGING
# ============================================================================
# Set to 1 to dump TTS audio frames to lk_dump/ directory (development only)
LK_DUMP_TTS=0

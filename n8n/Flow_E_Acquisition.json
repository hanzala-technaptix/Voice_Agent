    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8200/acquire",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"name\": \"{{ $json.body.name || $json.name || $json.fullName || $json.contact_name }}\",\n  \"phone\": \"{{ $json.body.phone || $json.phone || $json.mobile || $json.telephone }}\",\n  \"company\": \"{{ $json.body.company || $json.company || $json.organization }}\",\n  \"email\": \"{{ $json.body.email || $json.email || $json.email_address }}\",\n  \"title\": \"{{ $json.body.title || $json.title || $json.job_title }}\",\n  \"linkedin_url\": \"{{ $json.body.linkedin_url || $json.body.linkedin || $json.body.profile_url || $json.linkedin_url || $json.linkedin }}\",\n  \"campaign\": \"{{ $json.body.campaign || $json.body.utm_campaign || $json.utm_campaign || $json.campaign }}\",\n  \"timezone\": \"{{ $json.body.timezone || $json.timezone || \\\"\\\" }}\",\n  \"source\": \"{{ $json.body.source || $json.source || $json.utm_source || \\\"lead_acquisition\\\" }}\",\n  \"notes\": \"{{ $json.body.notes || $json.notes || \\\"\\\" }}\"\n}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json",
              "fullResponse": false
            }
          },
          "timeout": 15000
        }
      },
      "id": "http-acquire",
      "name": "POST /acquire",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,

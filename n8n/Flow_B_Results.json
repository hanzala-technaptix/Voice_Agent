        "googleSheetsOAuth2Api": {
          "id": "Xv56FMr5B7fHGuxY",
          "name": "Google Sheets account"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {

{
  "name": "Voice Agent \u2014 Flow B (Results Receiver)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "voice-results",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook",
      "name": "Webhook: /voice-results",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        240,
        400
      ],
      "webhookId": "voice-results"
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"ok\": true }",
        "options": {}
      },
      "id": "respond",
      "name": "Respond 200 OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        480,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const b = $input.item.json.body || $input.item.json;\nconst lead = b.lead || {};\nconst booking = b.booking || {};\nconst outcome = (b.outcome || 'no_answer').toString().toLowerCase();\n\nconst statusMap = {\n  booked: 'Booked',\n  declined: 'Declined',\n  callback: 'Callback Requested',\n  voicemail: 'Voicemail',\n  no_answer: 'No Answer',\n  incomplete: 'Hung up',\n};\n\nlet transcriptText = (b.transcript_text || '').toString();\nif (!transcriptText && b.transcript) {\n  const items = b.transcript.items || b.transcript.messages || [];\n  transcriptText = items.map(t => {\n    const role = (t.role || t.type || '').toLowerCase();\n    const label = role === 'user' ? 'Prospect' : 'Agent';\n    let content = t.content || t.text || '';\n    if (Array.isArray(content)) content = content.map(c => c.text || c).join(' ');\n    return content ? `${label}: ${content}` : '';\n  }).filter(Boolean).join('\\n');\n}\n\nconst interested = (b.interested === true || outcome === 'booked') ? 'true' : 'false';\nconst followUp = (b.follow_up_required === true || outcome === 'callback') ? 'true' : 'false';\n\nconst meetingNote = booking.start_label ? ` | meeting: ${booking.start_label}` : '';\nconst meetLink = booking.meet_link ? ` | ${booking.meet_link}` : '';\n\nreturn [{\n  json: {\n    lead_id: lead.lead_id || '',\n    phone: lead.phone || '',\n    name: lead.name || '',\n    email: lead.email || '',\n    call_status: statusMap[outcome] || 'No Answer',\n    call_outcome: outcome,\n    summary: b.summary || '',\n    transcript_text: transcriptText,\n    notes: (b.summary || '') + meetingNote + meetLink,\n    interested,\n    follow_up_required: followUp,\n    duration_sec: b.duration_sec || 0,\n    meeting_time: booking.start_label || '',\n    meet_link: booking.meet_link || '',\n    booking_id: booking.booking_id || '',\n    last_updated: new Date().toISOString(),\n  }\n}];"
      },
      "id": "normalize-payload",
      "name": "Parse Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        400
      ]
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": {
          "__rl": true,
          "value": "1QMFaVb1qLF-ymVsKRPo2goqM4qBSodux7PTWih2xEQQ",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Lead",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Lead ID": "={{ $json.lead_id }}",
            "Call Status": "={{ $json.call_status }}",
            "Call Outcome": "={{ $json.call_outcome }}",
            "notes": "={{ $json.notes }}",
            "Transcript": "={{ $json.transcript_text }}",
            "Last Updated": "={{ $json.last_updated }}"
          },
          "matchingColumns": [
            "Lead ID"
          ]
        }
      },
      "id": "sheets-update",
      "name": "Update CRM Row",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
